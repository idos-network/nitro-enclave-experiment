+public class FaceMapCoreMongoDataV10 {
+    public String faceMap = null;
+    public String responseBlob;
+    public BsonBinary auditTrailImage;
+    public BsonBinary officialIDPhotoImage = null;
+
+    public FaceMapCoreMongoDataV10(byte[] faceMap, String responseBlob, BsonBinary auditTrailImage, BsonBinary officialIDPhotoImage) {
