+package com.facetec.facetecserver.jsonobjects.primitives_v10;
+
+import com.facetec.facetecserver.helpers.ByteWrapper;
+import org.bson.BsonBinary;
+
+public class FaceMapCoreMongoDataV10 {
+    public String faceMap = null;
+    public String responseBlob;
+    public BsonBinary auditTrailImage;
+    public BsonBinary officialIDPhotoImage = null;
+
+    public FaceMapCoreMongoDataV10(byte[] faceMap, String responseBlob, BsonBinary auditTrailImage, BsonBinary officialIDPhotoImage) {
+        if (faceMap != null) {
+            this.faceMap = new ByteWrapper(faceMap).getBase64();
+        }
+
+        if (auditTrailImage != null) {
+            this.auditTrailImage = auditTrailImage;
+        }
+
+        this.responseBlob = responseBlob;
+
+        if (officialIDPhotoImage != null) {
+            this.officialIDPhotoImage = officialIDPhotoImage;
+        }
+    }
+}
