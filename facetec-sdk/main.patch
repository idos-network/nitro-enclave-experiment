+package com.facetec.facetecserver.jsonobjects.primitives_v10;
+
+import com.facetec.facetecserver.jsonobjects.primitives.CallMetadata;
+import com.facetec.facetecserver.jsonobjects.primitives.ServerInfo;
+
+//
+// The object that holds the results when requesting Session History Data for incomplete sessions.  This class is serialized using the gson lib.
+//
+public class CancelledSessionDatabaseMongoRecord {
+    public CallMetadata callData;
+    public AdditionalSessionDataV10 additionalSessionData;
+    public FaceTecResponseResult result;
+    public SessionHistoryCoreMongoData data;
+    public ServerInfo serverInfo;
+    public String launchId;
+    public String externalDatabaseRefID;
+
+    public CancelledSessionDatabaseMongoRecord(FaceTecResponseResult result, CallMetadata callData, AdditionalSessionDataV10 additionalSessionData, SessionHistoryCoreMongoData data, String launchId, String externalDatabaseRefID) {
+        this.result = result;
+        this.callData = callData;
+        this.additionalSessionData = additionalSessionData;
+        this.data = data;
+        this.serverInfo = new ServerInfo();
+        this.launchId = launchId;
+        this.externalDatabaseRefID = externalDatabaseRefID;
+    }
+}
