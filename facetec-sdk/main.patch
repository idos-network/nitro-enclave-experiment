+    private ClientEncryption getClientEncryption() {
+        if (clientEncryption == null) {
+            FaceTecLogging.info("-> Creating client encryption...");
+
+            MongoClientSettings mcs = MongoClientSettings
+                    .builder()
+                    .applyConnectionString(new ConnectionString(serverConfig.mongoDBURI))
+                    .build();
+
+            // https://www.mongodb.com/docs/manual/core/csfle/tutorials/aws/aws-automatic/?language-no-dependencies=java-sync#create-a-new-data-encryption-key
+            // check Authenticate with IAM Roles in Production
+            Map<String, Map<String, Object>> kmsProviders = new HashMap<>();
+            kmsProviders.put("aws", new HashMap<>());
+
+            ClientEncryptionSettings ces = ClientEncryptionSettings.builder()
+                    .keyVaultMongoClientSettings(mcs)
+                    .keyVaultNamespace(KEY_VAULT_NAMESPACE)
+                    .kmsProviders(kmsProviders)
+                    .build();
+
+            clientEncryption = ClientEncryptions.create(ces);
+        }
+
+        return clientEncryption;
+    }
+
+    private BsonBinary ensureFleKey() throws FaceTecServerExpectedException, MongoException {
+        @SuppressWarnings("resource")
+        MongoClient mongoClient = createOrGetCachedMongoClient();
+
+        if (mongoClient == null) {
+            throw new FaceTecServerExpectedException("FLE keys can't be saved, because of missing connection.");
+        }
+
+        try {
+            ClientEncryption enc = getClientEncryption();
+
+            BsonDocument existing = enc.getKeyByAltName(KEY_ALIAS);
+
+            if (existing != null) {
+                return existing.getBinary("_id");
+            }
+
+            FaceTecLogging.info("-> Creating fle key " + serverConfig.fleAwsKeyArn);
+            FaceTecLogging.info("-> Creating fle region " + serverConfig.fleAwsRegion);
+
+            DataKeyOptions opts = new DataKeyOptions()
+                    .masterKey(new BsonDocument()
+                            .append("key",
+                                    new BsonString(serverConfig.fleAwsKeyArn))
+                            .append("region",
+                                    new BsonString(serverConfig.fleAwsRegion)))
+                    .keyAltNames(List.of(KEY_ALIAS));
+
+            FaceTecLogging.info("-> Creating a data key...");
+            return enc.createDataKey("aws", opts);
+        } catch (MongoException e) {
+            FaceTecLogging.log(e.getMessage());
+            throw new MongoException("FLE keys can't be saved, of mongo exception: " + e.toString());
+        }
+    }
+
+    private BsonBinary encrypt(byte[] value) throws FaceTecServerExpectedException {
+        BsonBinary keyId = this.ensureFleKey();
+
+        return getClientEncryption().encrypt(
+                new BsonBinary(value),
+                new EncryptOptions("AEAD_AES_256_CBC_HMAC_SHA_512-Random")
+                        .keyId(keyId)
+        );
+    }
+
+    private byte[] decrypt(BsonBinary data) {
+        return getClientEncryption()
+                .decrypt(data)
+                .asBinary()
+                .getData();
+    }
